{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.opendata-kr/narajangteo-corpinfo",
  "description": "나라장터 사용자정보서비스(공공데이터포털 data.go.kr) Open API를 감싼 로컬 MCP 서버",
  "title": "나라장터 사용자정보",
  "websiteUrl": "https://github.com/opendata-kr/narajangteo-corpinfo-mcp#readme",
  "repository": {
    "url": "https://github.com/opendata-kr/narajangteo-corpinfo-mcp",
    "source": "github"
  },
  "icons": [
    {
      "src": "https://raw.githubusercontent.com/opendata-kr/.github/main/profile/images/avatar.svg",
      "mimeType": "image/svg+xml",
      "sizes": [
        "any"
      ]
    },
    {
      "src": "https://raw.githubusercontent.com/opendata-kr/.github/main/profile/images/avatar.png",
      "mimeType": "image/png",
      "sizes": [
        "512x512"
      ]
    }
  ],
  "version": "0.2.1",
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "@opendata-kr/narajangteo-corpinfo-mcp",
      "version": "0.2.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "DATA_GO_KR_SERVICE_KEY",
          "description": "공공데이터포털 data.go.kr Decoding(원본) 인증키",
          "isRequired": true,
          "isSecret": true
        },
        {
          "name": "DATA_GO_KR_BASE_URL",
          "description": "서비스 경로를 포함한 전체 base URL 오버라이드",
          "default": "https://apis.data.go.kr/1230000/ao/UsrInfoService02"
        }
      ]
    }
  ]
}
